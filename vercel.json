{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/docs/index.html"
    },
    {
      "src": "/config.js",
      "dest": "/docs/config.js"
    },
    {
      "src": "/(.*)",
      "dest": "/docs/$1"
    }
  ]
}
